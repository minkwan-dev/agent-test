# Nest (apps/api)
PORT=4000
CORS_ORIGIN=http://localhost:3000
FASTAPI_URL=http://127.0.0.1:8000

# Next (apps/web) — 로컬에서는 apps/web/.env.local 권장
NEXT_PUBLIC_API_URL=http://localhost:4000
# Nest JWT_SECRET 과 반드시 동일 (미들웨어·세션 쿠키 검증)
JWT_SECRET=change-me-to-a-long-random-string

# Nest Google/JWT/Supabase 전체 목록은 apps/api/.env.example 참고
